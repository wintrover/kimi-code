{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": ".tmp-api-extractor/dts",
    "rootDir": ".."
  },
  "include": [
    "src/**/*.ts",
    "../agent-core/src/**/*.ts",
    "../agent-core/src/prompt-modules.d.ts",
    "../kaos/src/**/*.ts",
    "../kosong/src/**/*.ts",
    "../oauth/src/**/*.ts"
  ],
  "exclude": ["dist", ".tmp-api-extractor", "examples", "test", "../*/dist", "../*/test"]
}
